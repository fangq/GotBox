object StatusForm: TStatusForm
  Left = 0
  Height = 460
  Top = 0
  Width = 600
  Caption = 'GotBox - Status'
  ClientHeight = 460
  ClientWidth = 600
  Position = poScreenCenter
  OnCreate = FormCreate
  LCLVersion = '4.2.0.0'
  object grid: TStringGrid
    Left = 12
    Height = 200
    Top = 12
    Width = 576
    Anchors = [akTop, akLeft, akRight]
    ColCount = 4
    FixedCols = 0
    RowCount = 1
    Options = [goFixedHorzLine, goFixedVertLine, goHorzLine, goVertLine, goRowSelect]
    TabOrder = 0
    ColWidths = (
      240
      110
      90
      130
    )
  end
  object lblLog: TLabel
    Left = 12
    Height = 16
    Top = 220
    Width = 80
    Caption = 'Activity log'
  end
  object mLog: TMemo
    Left = 12
    Height = 210
    Top = 240
    Width = 576
    Anchors = [akTop, akLeft, akRight, akBottom]
    ReadOnly = True
    ScrollBars = ssAutoBoth
    TabOrder = 1
  end
  object refreshTimer: TTimer
    Interval = 1500
    OnTimer = refreshTimerTimer
    Left = 540
    Top = 8
  end
end
