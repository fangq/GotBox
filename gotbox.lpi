  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <Target>
      <Filename Value="gotbox"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="src/ui;src/core"/>
      <OtherUnitFiles Value="src/ui;src/core"/>
      <UnitOutputDirectory Value="lib/$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Linking>
      <Options>
        <Win32>
          <GraphicApplication Value="True"/>
        </Win32>
      </Options>
    </Linking>
